# Optional runtime AI (Admin server only; leave blank for credential-free demo mode)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=medium
OPENAI_STORE=false

# Local synthetic demo behavior
DEMO_MODE=true
DEMO_ROLE=manager
SANDBOX_EMAIL_MODE=true
LEASEFLOW_DEMO_STATE_PATH=data/demo/.runtime/state.v1.json

# Expo variables are embedded into the Mobile Web bundle at build/start time.
EXPO_PUBLIC_LEASEFLOW_API_URL=http://localhost:3000

# Production SSO, Microsoft Graph, email, carrier-call, and company-system
# credentials are intentionally unsupported in this hackathon repository.
